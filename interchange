#include <cmath>
#include <cstdio>
#include <vector>
#include <iostream>
#include <algorithm>
using namespace std;


int main() {
    /* Enter your code here. Read input from STDIN. Print output to STDOUT */
    int n;
    cin>>n;
    vector<int>a(n);
        for(int i=0;i<n;i++){
            cin>>a[i];
        }
    int index1,index2;
    int min=a[0];
    int m=a[0];
    for(int i=0;i<n;i++){
        if(min>=a[i]){
            min=a[i];
            index1=i;
        }
        if(m<=a[i]){
            m=a[i];
            index2=i;
        }
    }  
    int temp;
        temp=a[index1];
        a[index1]=a[index2];
        a[index2]=temp;
        for(int i=0;i<n;i++){
            cout<<a[i]<<" ";
        }
    return 0;
}
